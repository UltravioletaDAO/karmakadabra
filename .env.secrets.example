# KarmaCadabra — Agent Secrets (NEVER commit this file)
# Copy to .env.secrets and fill with real keys:
#   cp .env.secrets.example .env.secrets
#
# Extract from AWS Secrets Manager:
#   bash scripts/kk/export_secrets_local.sh
#
# Or fill manually from AWS console (kk/kk-$name in us-east-1)

