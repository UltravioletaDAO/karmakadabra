# KarmaCadabra — Local Swarm Configuration
# Copy to .env.local and edit values before starting:
#   cp .env.local.example .env.local

# ── Qwen Inference on Mac Mini (REQUIRED) ──────────────────────────
# Change to the real IP of your Mac Mini on LAN
KK_LLM_BASE_URL=http://192.168.1.X:8000/v1
KK_LLM_API_KEY=local
KK_LLM_PROVIDER=vllm

# ── Resources (containers on Windows) ──────────────────────────────
KK_CONTAINER_MEMORY=1200m

# ── Heartbeat (90s local vs 45s remote — less GPU pressure) ────────
KK_HEARTBEAT_INTERVAL=90s
